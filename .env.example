# Ching Tech OS 應用程式設定
# 複製此檔案為 .env 並填入實際的值

# ===================
# 資料庫設定
# ===================
DB_HOST=localhost
DB_PORT=5432
DB_USER=ching_tech
DB_PASSWORD=your_db_password
DB_NAME=ching_tech_os

# ===================
# NAS 設定
# ===================
# 用於檔案管理、知識庫、專案附件等功能
NAS_HOST=192.168.11.50
NAS_PORT=445
NAS_USER=your_nas_user
NAS_PASSWORD=your_nas_password
NAS_SHARE=擎添開發

# NAS 掛載點路徑（由 install-service.sh 自動設定）
# 掛載架構：
#   /mnt/nas/ctos     → //NAS_HOST/擎添開發/ching-tech-os (讀寫)
#   /mnt/nas/projects → //NAS_HOST/擎添共用區/在案資料分享 (唯讀)
#   /mnt/nas/circuits → //NAS_HOST/擎添線路圖/圖檔 (唯讀)
#   /mnt/nas/library  → //NAS_HOST/擎添圖書館 (讀寫)
NAS_MOUNT_PATH=/mnt/nas
CTOS_MOUNT_PATH=/mnt/nas/ctos
PROJECTS_MOUNT_PATH=/mnt/nas/projects
CIRCUITS_MOUNT_PATH=/mnt/nas/circuits
LIBRARY_MOUNT_PATH=/mnt/nas/library
# SMB 連線逾時（秒，預設 10）
# SMB_CONNECT_TIMEOUT=10

# ===================
# Line Bot 設定
# ===================
# 從 Line Developers Console 取得
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_access_token

# ===================
# Telegram Bot 設定（可選）
# ===================
# 從 @BotFather 取得
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Webhook 驗證用 secret（自訂字串）
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret
# 管理員 Telegram 用戶 ID（啟動時發送上線通知）
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id

# ===================
# Session 設定
# ===================
# Session 有效時間（小時）
SESSION_TTL_HOURS=8

# ===================
# 路徑設定（可選，有預設值）
# ===================
# 前端靜態檔案目錄
FRONTEND_DIR=/home/ct/SDD/ching-tech-os/frontend

# NAS 路徑（相對於 CTOS_MOUNT_PATH，由 property 組合為本機完整路徑）
KNOWLEDGE_NAS_PATH=knowledge
PROJECT_NAS_PATH=projects
LINEBOT_NAS_PATH=linebot/files

# 本機路徑
PROJECT_ATTACHMENTS_PATH=/home/ct/SDD/ching-tech-os/data/projects/attachments

# ===================
# Bot 設定
# ===================
# 用於加密 bot_settings 資料庫中的憑證（留空則使用預設開發金鑰）
# BOT_SECRET_KEY=your_secret_key
# 未綁定用戶策略：reject（拒絕）| restricted（受限模式）
BOT_UNBOUND_USER_POLICY=restricted
# 受限模式使用的 AI 模型（預設 haiku）
# BOT_RESTRICTED_MODEL=haiku
# 預設受限 Agent ID（留空則使用系統預設）
# BOT_DEFAULT_RESTRICTED_AGENT=
# /debug 指令使用的模型（預設 sonnet）
# BOT_DEBUG_MODEL=sonnet
# 停用指令（逗號分隔，如 debug,agent）
# BOT_CMD_DISABLED=
# 頻率限制（受限模式適用）
# BOT_RATE_LIMIT_ENABLED=false
# BOT_RATE_LIMIT_HOURLY=10
# BOT_RATE_LIMIT_DAILY=50

# ===================
# 系統設定
# ===================
# 公開 URL（用於分享連結、Webhook 等）
PUBLIC_URL=https://ching-tech.ddns.net/ctos
# 啟用模組清單（* = 全部啟用，逗號分隔指定模組）
# ENABLED_MODULES=*
# 是否啟用 NAS SMB 認證（預設 true）
# ENABLE_NAS_AUTH=true

# ===================
# Skill 系統設定
# ===================
# 外部 skills 目錄（external-first 載入，優先於內建 skills）
# SKILL_EXTERNAL_ROOT=~/SDD/external-skills
# 工具路由策略：script-first | mcp-first
# SKILL_ROUTE_POLICY=script-first
# script 失敗時是否 fallback 到對應 MCP tool
# SKILL_SCRIPT_FALLBACK_ENABLED=true

# ===================
# 文件轉換服務（可選，有預設值）
# ===================
# MD2PPT_URL=https://md-2-ppt-evolution.vercel.app
# MD2DOC_URL=https://md-2-doc-evolution.vercel.app

# ===================
# Nanobanana 設定（AI 圖片生成）
# ===================
NANOBANANA_GEMINI_API_KEY=your_gemini_api_key
NANOBANANA_MODEL=gemini-3-pro-image-preview
# 圖片輸出目錄（Line Bot 需要設定到 NAS 路徑讓後端可以存取）
NANOBANANA_OUTPUT_DIR=/mnt/nas/ctos/linebot/files/ai-images
# API 超時秒數（預設 60）
NANOBANANA_TIMEOUT=180
# 單回合 nanobanana 工具最多呼叫次數（避免模型在同回合重複產圖；0 表示不限制）
NANOBANANA_MAX_CALLS_PER_REQUEST=1

# ===================
# Hugging Face 設定（圖片生成備用服務）
# ===================
HUGGINGFACE_API_TOKEN=your_huggingface_api_token

# ===================
# Pexels API 設定（簡報配圖）
# ===================
PEXELS_API_KEY=your_pexels_api_key

# ===================
# Brave Search API 設定（research-skill 優先搜尋 provider）
# ===================
# 申請網址：https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=your_brave_search_api_key
# research worker 預設模型（建議 claude-opus 提升研究品質）
RESEARCH_CLAUDE_MODEL=claude-opus
# 背景 Claude WebSearch/WebFetch timeout（秒，預設 300 = 5 分鐘）
RESEARCH_CLAUDE_TIMEOUT_SEC=300
# check-research 逾時判定分鐘（建議大於 claude timeout + fallback pipeline，預設 15）
RESEARCH_STALE_TIMEOUT_MINUTES=15

# ===================
# ERPNext 設定（MCP 整合）
# ===================
# ERPNext 伺服器位址
ERPNEXT_URL=http://your-erpnext-server
# 從 ERPNext User 設定中產生 API Key/Secret
ERPNEXT_API_KEY=your_api_key
ERPNEXT_API_SECRET=your_api_secret
